# Copy this to .env and fill in your Connected App details
# Get these from: Setup > App Manager > Your Connected App

# Your Connected App's Consumer Key
VITE_SF_CLIENT_ID=your_consumer_key_here

# Your Connected App's Consumer Secret
# ⚠️  WARNING: In production, NEVER expose client_secret in frontend code
# Use a backend proxy/server to exchange the code for a token
VITE_SF_CLIENT_SECRET=your_consumer_secret_here

# Salesforce login URL
# Production: https://login.salesforce.com
# Sandbox:    https://test.salesforce.com
VITE_SF_LOGIN_URL=https://login.salesforce.com

# OAuth Redirect URI — must EXACTLY match what's in your Connected App settings
VITE_SF_REDIRECT_URI=http://localhost:3000/oauth/callback
